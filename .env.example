# MentorMind Environment Configuration
# Copy this file to .env and fill in your values

# ===== DEEPSEEK API CONFIGURATION =====
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== AI SERVICE ENDPOINTS =====
# Optional: Set these to connect to real AI services
# FunASR for audio transcription
FUNASR_API_URL=http://localhost:8888
FUNASR_API_KEY=your_funasr_api_key_optional

# PaddleOCR for text extraction
PADDLEOCR_API_URL=http://localhost:8889
PADDLEOCR_API_KEY=your_paddleocr_api_key_optional

# TTS for text-to-speech
TTS_API_URL=http://localhost:8890
TTS_API_KEY=your_tts_api_key_optional

# ===== APPLICATION SETTINGS =====
# Environment: development, staging, production
MENTORMIND_ENV=development

# ===== DATABASE CONFIGURATION (Optional) =====
# PostgreSQL for metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mentormind
POSTGRES_PASSWORD=mentormind

# Redis for caching (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== SECURITY NOTES =====
# 1. Never commit .env file to version control
# 2. Use different keys for development/production
# 3. Rotate API keys regularly
# 4. Use environment-specific configurations