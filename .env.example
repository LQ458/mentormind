# MentorMind Environment Configuration
# Copy this file to .env and fill in your values

# ===== DEEPSEEK API CONFIGURATION =====
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== AI SERVICE ENDPOINTS =====
# Self-hosted Chinese AI Services (aliyun-funasr & baidu-paddleocr)
# Defaults match docker-compose.yml ports
FUNASR_ENDPOINT=http://localhost:10095
PADDLE_OCR_ENDPOINT=http://localhost:8866

# Video Generation (Optional - Future Integration)
# Use HeyGen or SiliconFlow for Avatar Video
HEYGEN_API_KEY=
SILICONFLOW_API_KEY=

# ===== VOLCENGINE TTS CONFIGURATION =====
# Get your credentials from: https://console.volcengine.com/speech/app
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=

# Environment: development, staging, production
MENTORMIND_ENV=development

# Better Auth — self-hosted authentication secret (shared between frontend and backend)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production

# ===== FRONTEND SECURITY =====
# For Next.js 14 CSRF protection
# When deploying remotely, set this to the public URL/IP of the frontend
# Example: ALLOWED_ORIGIN=124.156.132.192:3000
ALLOWED_ORIGIN=

# FastAPI CORS allowlist, comma-separated.
# Example: CORS_ORIGINS=https://example.com,https://www.example.com
CORS_ORIGINS=

# Public app origin. In VPS Docker production this should be your public URL.
# Example: NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Leave blank for same-origin production WebSockets through nginx /ws/.
# Set only when the browser must connect to a separate backend WS origin.
NEXT_PUBLIC_BACKEND_WS_URL=

# Next.js API route proxy target (FastAPI backend)
# IMPORTANT: Use 127.0.0.1 instead of localhost to prevent IPv6 connection errors
BACKEND_URL=http://127.0.0.1:8000

# ===== DATABASE CONFIGURATION (Optional) =====
# PostgreSQL for metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mentormind
POSTGRES_PASSWORD=mentormind
POSTGRES_DB=mentormind_metadata

# Redis for caching (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== PRODUCTION DOCKER =====
# Used by docker-compose.prod.yml and scripts/deploy-prod.sh on a VPS.
MENTORMIND_IMAGE_TAG=prod
HTTP_PORT=80

# ===== CLOUD STORAGE (Optional) =====
S3_ENABLED=false
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=mentormind-videos
S3_PUBLIC_URL_PREFIX=

# ===== SECURITY NOTES =====
# 1. Never commit .env file to version control
# 2. Use different keys for development/production
# 3. Rotate API keys regularly
# 4. Use environment-specific configurations
