      "element_id": "d5c3e303-c84a-4091-aac2-2aafb386a51e",
      "data": {
        "element_type": "step_list",
        "content": "力越大 → 加速度越大（推力越大，车加速越快）",
        "position": {
          "region": "center",
          "offset_x": 0,
          "offset_y": 0
        },
        "style": {
          "color": "green",
          "size": "medium",
          "animation": "grow"
        },
        "narration": "三个关键直觉：力越大加速度越大；质量越大加速度越小；加速度方向和力的方向一致。这三条直觉，就是牛顿第二定律的核心。",
        "metadata": {
          "steps": [
            "力越大 → 加速度越大（推力越大，车加速越快）",
            "质量越大 → 加速度越小（车越重，越难加速）",
            "加速度方向与力的方向相同（往哪推，往哪动）"
          ]
        }
      }
    },
